{
  "id": "device-list-and-delete",
  "lang": "zh",
  "category": "device",
  "workflow": "device-onboarding",
  "scenario_type": "multi_turn",
  "description": "多轮：列出设备 → 删除其中一个",
  "setup": { "fixture": "seed-default" },
  "turns": [
    { "user": "列出当前所有设备" },
    { "user": "请删除 camera-001" }
  ],
  "applies": ["tool_accuracy", "task_completion", "context_retention", "response_quality", "language_adherence"],
  "expectations": {
    "per_turn": [
      "Turn 1: Agent 调用 `neomind device list`，应返回 3 个设备",
      "Turn 2: Agent 调用 `neomind device delete camera-001`，引用上一轮列表中的设备"
    ],
    "overall": "第二轮必须真正执行删除"
  },
  "state_queries": [
    { "type": "device_exists", "params": { "id": "camera-001" }, "expected": false }
  ]
}
