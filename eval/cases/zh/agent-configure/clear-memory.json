{
  "id": "agent-clear-memory",
  "lang": "zh",
  "category": "agent",
  "workflow": "agent-configure",
  "scenario_type": "single_turn",
  "description": "清除某个 agent 的记忆（覆盖 `neomind agent clear-memory` — 重置陈旧知识路径）",
  "setup": {
    "fixture": "seed-empty",
    "extras": {
      "agents": [
        {
          "name": "demo-agent",
          "user_prompt": "demo",
          "schedule": { "schedule_type": "interval", "interval_seconds": 60 },
          "execution_mode": "free"
        }
      ]
    }
  },
  "turns": [
    { "user": "demo-agent 积累了过时的知识，请帮我清空它的记忆。" }
  ],
  "applies": ["tool_accuracy", "task_completion", "language_adherence"],
  "expectations": {
    "per_turn": [
      "Turn 1: Agent 先解析出 demo-agent 的 id，再调用 `neomind agent clear-memory <id>`"
    ],
    "overall": "应明确确认记忆已清空"
  }
}
