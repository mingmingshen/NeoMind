{
  "id": "agent-pause-existing",
  "lang": "en",
  "category": "agent",
  "workflow": "agent-configure",
  "scenario_type": "single_turn",
  "description": "Pause an existing agent",
  "setup": {
    "fixture": "seed-empty",
    "extras": {
      "agents": [
        {
          "name": "demo-agent",
          "user_prompt": "demo",
          "schedule": { "schedule_type": "interval", "interval_seconds": 60 },
          "execution_mode": "free"
        }
      ]
    }
  },
  "turns": [
    { "user": "Pause the agent named 'demo-agent'." }
  ],
  "applies": ["tool_accuracy", "task_completion", "language_adherence"],
  "expectations": {
    "per_turn": [
      "Turn 1: Agent resolves demo-agent's id, then invokes `neomind agent control <id> paused`"
    ],
    "overall": "Must fetch the agent id before issuing the control command"
  }
}
