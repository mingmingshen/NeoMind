{
  "id": "rule-create-high-temp",
  "lang": "en",
  "category": "rule",
  "workflow": "rule-management",
  "scenario_type": "single_turn",
  "description": "Create a high-temperature alert rule",
  "setup": { "fixture": "seed-default" },
  "turns": [
    { "user": "Create a rule: notify me when sensor-001 temperature exceeds 35. Name it high-temp-warning" }
