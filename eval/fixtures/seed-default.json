{
  "name": "seed-default",
  "description": "Default seed: 2 temp sensors + 1 camera + 1 temperature alert rule",
  "devices": [
    {
      "id": "sensor-001",
      "name": "Living Room Sensor",
      "device_type": "temp_sensor",
      "adapter_type": "mqtt",
      "connection_config": {}
    },
    {
      "id": "sensor-002",
      "name": "Bedroom Sensor",
      "device_type": "temp_sensor",
      "adapter_type": "mqtt",
      "connection_config": {}
    },
    {
      "id": "camera-001",
      "name": "Front Door Camera",
      "device_type": "ip_camera",
      "adapter_type": "mqtt",
      "connection_config": {}
    }
  ],
  "metrics": [
    { "device_id": "sensor-001", "metric": "temperature", "value": 22.5 },
    { "device_id": "sensor-001", "metric": "humidity", "value": 55.0 },
    { "device_id": "sensor-002", "metric": "temperature", "value": 24.1 },
    { "device_id": "sensor-002", "metric": "humidity", "value": 60.0 }
  ],
  "rules": [
    {
      "name": "rule-temp-alert",
      "description": "Alert when sensor-001 temperature exceeds 30",
      "condition": {
        "type": "comparison",
        "field": "device:sensor-001:temperature",
        "operator": ">",
        "value": 30
      },
      "actions": [
        { "type": "notify", "message": "Temperature too high on sensor-001" }
      ],
      "trigger": "metric_update",
      "cooldown": 60,
      "enabled": true
    }
  ]
}
