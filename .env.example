# =============================================================================
# NeoMind Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Full reference: https://wiki.camthink.ai/en/docs/neomind/user-guide/install-setup
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# HTTP API + Web UI host port mapping (Docker only; default: 9375)
NEOMIND_HTTP_PORT=9375

# MQTT broker port for device connections (Docker only; default: 1883)
NEOMIND_MQTT_PORT=1883

# Server bind host (default: 0.0.0.0)
# NEOMIND_HOST=0.0.0.0

# Server bind port (default: 9375)
# NEOMIND_PORT=9375

# Data directory for all databases (default: data)
# NEOMIND_DATA_DIR=data

# Public hostname or IP for callback URLs (default: auto-detect LAN IP)
# NEOMIND_PUBLIC_HOST=

# Server base URL for generating externally-visible URLs (webhook endpoints,
# device onboarding URLs returned to UI/CLI, etc.). Default: http://localhost:9375.
#
# Priority chain (first match wins):
#   1. This env var — explicit operator config. ALWAYS set this for production.
#   2. X-Forwarded-Proto + Host request headers — auto-inferred when behind a
#      reverse proxy (nginx/Caddy TLS termination). The server has to actually
#      be behind a proxy you control — otherwise attackers can spoof these.
#   3. http://localhost:9375 fallback — only correct for local single-user setups.
#
# For HTTPS reverse-proxy deployments, set this explicitly:
#   NEOMIND_SERVER_URL=https://your.domain.com
# NEOMIND_SERVER_URL=http://localhost:9375

# Frontend static files directory — non-embedded mode only (default: /var/www/neomind)
# NEOMIND_WEB_DIR=/var/www/neomind

# -----------------------------------------------------------------------------
# Authentication & Encryption
# -----------------------------------------------------------------------------

# JWT secret — set this for persistent auth across container restarts.
# If not set, a random secret is generated each restart (sessions will be invalidated).
# NEOMIND_JWT_SECRET=

# Data encryption key — set this for persistent encryption across container restarts.
# If not set, the key is auto-generated and stored in data/encryption_key.
# NEOMIND_ENCRYPTION_KEY=

# API key for CLI authentication (optional)
# NEOMIND_API_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level (default: info)
# Options: trace, debug, info, warn, error (supports module filters)
RUST_LOG=neomind=info

# Timezone (default: system timezone)
TZ=Asia/Shanghai

# Enable JSON-formatted log output (default: off)
# NEOMIND_LOG_JSON=true

# Force colored terminal output (default: auto)
# NEOMIND_COLOR=true

# -----------------------------------------------------------------------------
# Agent & LLM
# -----------------------------------------------------------------------------

# Default LLM provider for neomind setup: ollama, openai
# LLM_PROVIDER=ollama

# Default model name (default: qwen3.5:4b for Ollama, gpt-4o-mini for OpenAI)
# LLM_MODEL=qwen3.5:4b

# Ollama API endpoint (default: http://localhost:11434)
# OLLAMA_ENDPOINT=http://localhost:11434

# OpenAI-compatible API key
# OPENAI_API_KEY=

# OpenAI-compatible API endpoint (default: https://api.openai.com/v1)
# OPENAI_ENDPOINT=https://api.openai.com/v1

# Maximum tool-calling iterations per agent turn (default: 20)
# NEOMIND_MAX_TOOL_ITERATIONS=20

# Agent streaming response timeout in seconds (default: 1200 = 20 minutes)
# NEOMIND_STREAM_TIMEOUT=

# WebSocket heartbeat interval in seconds (default: 30)
# NEOMIND_HEARTBEAT_INTERVAL=

# Directories the shell tool is allowed to write to (colon-separated)
# NEOMIND_ALLOWED_WRITE_DIRS=

# Maximum context window size in tokens (default: 128000)
# AGENT_MAX_CONTEXT_TOKENS=128000

# Global upper limit for model context length (default: unlimited)
# NEOMIND_MAX_CONTEXT=

# Maximum tokens to generate per LLM response (default: 4096)
# AGENT_MAX_TOKENS=4096

# LLM sampling temperature, lower = more deterministic (default: 0.3)
# AGENT_TEMPERATURE=0.3

# LLM top-p sampling parameter (default: 0.7)
# AGENT_TOP_P=0.7

# Maximum concurrent LLM requests from agent (default: 3)
# AGENT_CONCURRENT_LIMIT=3

# Token budget for context selector (default: 4000)
# AGENT_CONTEXT_SELECTOR_TOKENS=4000

# Unified LLM request timeout in seconds (overrides per-backend defaults)
# AGENT_LLM_TIMEOUT_SECS=

# --- Per-backend timeouts (seconds) ---
# OLLAMA_TIMEOUT_SECS=120
# OPENAI_TIMEOUT_SECS=60
# ANTHROPIC_TIMEOUT_SECS=60
# GOOGLE_TIMEOUT_SECS=60
# XAI_TIMEOUT_SECS=60
# QWEN_TIMEOUT_SECS=60
# DEEPSEEK_TIMEOUT_SECS=60
# GLM_TIMEOUT_SECS=60
# MINIMAX_TIMEOUT_SECS=60
# LLAMACPP_TIMEOUT_SECS=180

# -----------------------------------------------------------------------------
# Extension Runtime
# -----------------------------------------------------------------------------

# FFI call timeout in seconds, minimum 10 (default: 120)
# NEOMIND_FFI_TIMEOUT_SECS=120

# Maximum IPC message size in bytes (default: 10485760 = 10 MB)
# NEOMIND_IPC_MAX_SIZE=10485760

# WASM linear memory limit per extension in MB (default: 256)
# NEOMIND_WASM_MEMORY_MB=256

# Maximum WASM binary file size in MB (default: 50)
# NEOMIND_WASM_MAX_SIZE_MB=50

# WASM execution fuel limit (default: 1000000)
# NEOMIND_WASM_FUEL=1000000

# Dashboard component marketplace base URL (default: GitHub raw URL)
# NEOMIND_MARKET_URL=

# -----------------------------------------------------------------------------
# CLI
# -----------------------------------------------------------------------------

# API base URL for CLI commands (default: http://localhost:9375/api).
# For remote/HTTPS deployments, set to the public URL including scheme:
#   NEOMIND_API_BASE=https://your.domain.com/api
# Without this, `neomind system info` will report webhook URLs with the
# localhost fallback scheme even if the server is behind an HTTPS proxy —
# the CLI is an HTTP client and can't see X-Forwarded-Proto itself.
# NEOMIND_API_BASE=http://localhost:9375/api

# Force JSON output format (set to any value)
# NEOMIND_JSON=1

# -----------------------------------------------------------------------------
# Frontend (Vite — build-time only)
# -----------------------------------------------------------------------------

# API base URL for cross-origin deployment
# VITE_API_BASE_URL=

# Vite dev server proxy target (default: http://127.0.0.1:9375)
# VITE_API_TARGET=http://127.0.0.1:9375
