# Build artifacts — **/target/ catches nested Rust caches too. Plain `target/`
# only matched the workspace root, so web/src-tauri/target (~22GB, the Tauri
# desktop build cache) leaked into `COPY web/` and crashed the build (EIO).
**/target/
**/*.rs.bk
web/node_modules/
web/dist/
web/src-tauri/gen/

# Runtime data
data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Claude / plugins
.claude/

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Docs (not needed in image)
docs/

# OS
.DS_Store
Thumbs.db

# Misc
*.md
!crates/**/README.md
LICENSE
